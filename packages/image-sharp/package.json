{
  "name": "@effect-pantry/image-sharp",
  "version": "0.1.0",
  "description": "Sharp-based image processing adapter for @effect-pantry/image",
  "keywords": [
    "effect",
    "image",
    "sharp",
    "image-processing"
  ],
  "homepage": "https://github.com/nipakke/effect-pantry/tree/main/packages/image-sharp#readme",
  "bugs": {
    "url": "https://github.com/nipakke/effect-pantry/issues"
  },
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nipakke/effect-pantry.git",
    "directory": "packages/image-sharp"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && tsgo",
    "test": "vitest run",
    "check": "vp check",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@effect-pantry/image": "workspace:*",
    "effect": "catalog:effect3",
    "sharp": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:effect3",
    "@tooling/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/ui": "catalog:",
    "rimraf": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
