{
  "name": "@effect-pantry/watch-fs",
  "version": "0.0.2",
  "description": "Effect-native file watching — wraps chokidar as Effect Streams with typed events and Scope-based resource management",
  "keywords": [
    "chokidar",
    "effect",
    "file-watching"
  ],
  "homepage": "https://github.com/nipakke/effect-pantry/tree/main/packages/watch-fs#readme",
  "bugs": {
    "url": "https://github.com/nipakke/effect-pantry/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nipakke/effect-pantry.git",
    "directory": "packages/watch-fs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && tsgo",
    "test": "vitest run",
    "check": "vp check",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@effect/platform": "catalog:effect3",
    "chokidar": "catalog:",
    "effect": "catalog:effect3"
  },
  "devDependencies": {
    "@effect/platform-node": "catalog:effect3",
    "@effect/vitest": "catalog:effect3",
    "@tooling/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "rimraf": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
