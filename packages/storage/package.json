{
  "name": "@effect-pantry/storage",
  "version": "0.0.0",
  "private": true,
  "description": "Effect-native storage — wraps files-sdk as typed Effect functions with scope-managed lifecycle",
  "keywords": [
    "effect",
    "files-sdk",
    "file-storage",
    "s3",
    "r2"
  ],
  "homepage": "https://github.com/nipakke/effect-pantry/tree/main/packages/storage#readme",
  "bugs": {
    "url": "https://github.com/nipakke/effect-pantry/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nipakke/effect-pantry.git",
    "directory": "packages/storage"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && tsgo",
    "test": "vitest run",
    "check": "vp check",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "effect": "catalog:effect3"
  },
  "peerDependencies": {
    "files-sdk": "^1.6.0"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:effect3",
    "@tooling/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/ui": "catalog:",
    "rimraf": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
