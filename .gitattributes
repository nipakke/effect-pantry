# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Source files
*.ts      text diff=typescript
*.tsx     text diff=typescript
*.js      text
*.json    text
*.yaml    text
*.yml     text
*.md      text
*.sh      text eol=lf
bash      text eol=lf
*.env     text

# Configs
.gitignore text
.npmrc     text
.node-version text
.editorconfig text

# Lockfile — treat as binary to avoid merge diff noise
pnpm-lock.yaml -diff

# Generated / build outputs
dist/     -text
*.tsbuildinfo -text

# Binaries
*.png     binary
*.jpg     binary
*.jpeg    binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.eot     binary
*.ttf     binary
